<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flaps OTA Uploader"
        android:textSize="24sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/targetGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/radioFirmware"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Firmware"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radioSpiffs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPIFFS File" />
    </RadioGroup>

    <EditText
        android:id="@+id/editRemotePath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Remote Path (e.g. /spiffs/config.json)"
        android:visibility="gone"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnSelectFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select File"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/textSelectedFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No file selected"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnUpload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload"
        android:layout_marginTop="16dp"
        android:enabled="false" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:max="100" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Idle"
        android:layout_marginTop="8dp" />

</LinearLayout>
